# ==================== APPLICATION SETTINGS ====================
NODE_ENV=development
PORT=4000
BASE_URL=http://localhost:4000

# ==================== DATABASE SETTINGS ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dhamini_db
DB_USER=dhamini_user
DB_PASSWORD=your-secure-here
DB_POOL_MAX=20
DB_POOL_MIN=5

# ==================== REDIS SETTINGS ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT SETTINGS ====================
JWT_SECRET=dhamini-secret-key-2025-change-in-production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ==================== ENCRYPTION SETTINGS ====================
ENCRYPTION_KEY=dhamini-encryption-key-32-bytes-long

# ==================== M-PESA DARAJA SETTINGS ====================
MPESA_CONSUMER_KEY=sandbox-key
MPESA_CONSUMER_SECRET=sandbox-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279c9bbddc2282017786915918f34a926b1d126781877d8e05
MPESA_CALLBACK_URL=https://your-domain.com/api/repayments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke/mpesa

# ==================== SMS GATEWAY SETTINGS ====================
SMS_GATEWAY_URL=https://api.africastalking.com/version1/messaging
SMS_GATEWAY_API_KEY=your-africasalking-api-key
SMS_GATEWAY_USERNAME=dhamini

# ==================== EXTERNAL VERIFICATION APIS ====================
IPRS_API_URL=https://test-api.iprs.go.ke/verify
IPRS_API_KEY=your-iprs-api-key
KRA_API_URL=https://test-api.kra.go.ke/validate-pin
KRA_API_KEY=your-kra-api-key

# ==================== HYPERLEDGER FABRIC SETTINGS ====================
# Connection Profile Path (relative to backend directory)
FABRIC_CONNECTION_PROFILE=../fabric-connection-profile.yaml

# Network Settings
FABRIC_CHANNEL=dhaminichannel
FABRIC_CHAINCODE=dhaminicontract
FABRIC_CHAINCODE_VERSION=1.0
FABRIC_MSP_ID=DhaminiMSP
FABRIC_ORG_NAME=Dhamini

# Gateway Connection
FABRIC_PEER=localhost:7051
FABRIC_CONNECTION_TIMEOUT=30
FABRIC_TLS=false
FABRIC_SERVER_HOST_NAME=peer0.dhamini.example.com

# WALLET
FABRIC_WALLET_PATH=./wallet

# IDENTITY
FABRIC_ADMIN_ID=admin
FABRIC_APP_ID=appUser

# TIMEOUTS
FABRIC_INVOKE_TIMEOUT=60
FABRIC_QUERY_TIMEOUT=30

# LOGGING
FABRIC_LOG_LEVEL=info

# ==================== LOGGING SETTINGS ====================
LOG_LEVEL=info

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
